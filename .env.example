# Copy this file to ".env" and fill in your values. NEVER commit your real .env.

# --- Gemini AI (for screenshot auto-fill) ---
# Get a key at https://aistudio.google.com/apikey (it starts with "AIzaSy").
# You can set a second/third key as automatic failover.
GEMINI_API_KEY=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=

# --- Optional: live sharing to a Google Sheet (see README "Live sharing") ---
# Path to your Google service-account JSON key (keep it OUT of git).
GOOGLE_SERVICE_ACCOUNT_JSON=service_account.json
# Spreadsheet ID — from the sheet URL: /spreadsheets/d/<THIS_PART>/edit
GSHEET_ID=
# Worksheet/tab name to append rows to (created automatically if missing)
GSHEET_WORKSHEET=Mistakes
# Optional: Drive folder ID to upload screenshots into (enables screenshot links)
GDRIVE_FOLDER_ID=

# --- Optional ---
# Override where local data (Excel + screenshots) is stored. Default: ./data
# DATA_DIR=
